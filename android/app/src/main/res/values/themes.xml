<resources>
    <style name="Theme.HttpFileServer" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="actionBarStyle">@style/Theme.HttpFileServer.ActionBar</item>
    </style>

    <style name="Theme.HttpFileServer.ActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/accent</item>
        <item name="titleTextStyle">@style/Theme.HttpFileServer.ActionBar.Title</item>
    </style>

    <style name="Theme.HttpFileServer.ActionBar.Title" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">#FFFFFF</item>
    </style>
</resources>
