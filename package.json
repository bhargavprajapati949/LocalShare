{
  "name": "localshare",
  "productName": "LocalShare",
  "version": "1.1.2",
  "description": "Seamless, cross-platform local network file sharing",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": "dist/server/server.js",
  "scripts": {
    "dev": "tsx watch src/server/server.ts",
    "build": "node scripts/build.mjs",
    "start": "node dist/server/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx src/server/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage --import tsx src/server/*.test.ts",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:all": "npm run build && electron-builder -mwl"
  },
  "keywords": [
    "file-sharing",
    "local-network",
    "lan",
    "electron"
  ],
  "author": "Bhargav Prajapati <bhargavprajapati949@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "@types/multer": "^2.1.0",
    "archiver": "^7.0.1",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.6",
    "electron-store": "^11.0.2",
    "express": "^5.2.1",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.10",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.localshare.app",
    "productName": "LocalShare",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "public/icons/mac/icon.icns",
      "artifactName": "${productName}-mac-${arch}.${ext}",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/icons/win/icon.ico",
      "artifactName": "${productName}.${ext}",
      "target": "nsis"
    },
    "linux": {
      "icon": "public/icons/png/512x512.png",
      "artifactName": "${productName}-linux-${arch}.${ext}",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Utility"
    }
  }
}
