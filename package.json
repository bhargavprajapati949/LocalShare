{
  "name": "localshare",
  "version": "1.0.7",
  "description": "Cross-platform local network HTTP file host prototype",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": "dist/server/server.js",
  "scripts": {
    "dev": "tsx watch src/server/server.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/renderer && cp -r src/renderer/* dist/renderer/",
    "start": "node dist/server/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx src/server/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage --import tsx src/server/*.test.ts",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "package:clean": "rm -rf release",
    "package:host": "npm run build && node scripts/package-host.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/multer": "^2.1.0",
    "archiver": "^7.0.1",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.6",
    "electron-store": "^11.0.2",
    "express": "^5.2.1",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^41.3.0",
    "postcss": "^8.5.10",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.localshare.app",
    "productName": "LocalShare",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release-electron"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
