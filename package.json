{
  "name": "httpfileserverclone",
  "version": "1.0.0",
  "description": "Cross-platform local network HTTP file host prototype",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx src/app.test.ts src/fileService.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mime-types": "^3.0.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
