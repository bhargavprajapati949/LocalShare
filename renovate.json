{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "gitAuthor": "Renovate Bot <bot@yourdomain.com>",
  "dependencyDashboard": true,
  "rangeStrategy": "pin",
  "timezone": "UTC",
  "schedule": [
    "* 3 1 * *"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "All non-major dependencies",
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true
    },
    {
      "matchPackageNames": [
        "node",
        "@types/node"
      ],
      "allowedVersions": "^20.0.0"
    }
  ]
}